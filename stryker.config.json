{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": { "fileName": "test/stryker/mutation-report.html" },
  "jsonReporter": { "fileName": "test/stryker/mutation-report.json" },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/index.ts",
    "!src/types.ts",
    "!src/core/I*.ts"
  ],
  "thresholds": { "high": 90, "low": 70, "break": 80 }
}
